{
    "task_type": "self_intro_generate",
    "input": {
        "tone": {
            "type": "string",
            "required": true,
            "enum": [
                "formal",
                "conversational"
            ]
        },
        "resume_item": {
            "type": "string",
            "required": true,
            "min_length": 10,
            "description": "用户输入的简历内容"
        },
        "target_jd_keywords": {
            "type": "array",
            "required": false,
            "description": "来自 jd_analyze 输出的 key_skills"
        },
        "hard_requirements": {
            "type": "array",
            "max": 15
        },
        "nice_to_have": {
            "type": "array",
            "required": false,
            "max": 15
        },
        "role_summary": {
            "type": "string",
            "required": false,
            "min_length": 10
        }
    },
    "output": {
        "version_30s": {
            "type": "string",
            "required": true
        },
        "version_60s": {
            "type": "string",
            "required": true
        },
        "key_points": {
            "type": "array",
            "required": true
        }
    },
    "error_cases": {
        "tone_empty": " tone为空时返回错误"
    },
    "constraints": [
        "resume_item不能少于10字",
        "不能添加用户未提及的经历",
        "不能添加与目标角色无关的信息"
    ]
}