{
    "task_type": "resume_optimize",
    "input": {
        "resume_item": {
            "type": "string",
            "required": true,
            "min_length": 10,
            "description": "用户输入的简历内容"
        },
        "target_jd_keywords": {
            "type": "array",
            "required": false,
            "description": "来自 jd_analyze 输出的 key_skills"
        },
        "hard_requirements": {
            "type": "array",
            "max": 15
        },
        "nice_to_have": {
            "type": "array",
            "required": false,
            "max": 15
        },
        "role_summary": {
            "type": "string",
            "required": false,
            "min_length": 10
        }
    },
    "output": {
        "original": {
            "type": "string",
            "required": true,
            "min_length": 10
        },
        "suggestions": {
            "type": "array",
            "required": true,
            "min": 1,
            "items": {
                "type": "object",
                "properties": {
                    "issue": {
                        "type": "string",
                        "required": true,
                        "min_length": 10
                    },
                    "reason": {
                        "type": "string",
                        "required": true,
                        "min_length": 10
                    },
                    "rewrite": {
                        "type": "string",
                        "required": true,
                        "min_length": 10
                    }
                }
            }
        },
        "optimized_version": {
            "type": "string",
            "required": true,
            "min_length": 10
        }
    },
    "error_cases": {
        "resume_item_too_short": "resume_item 少于 10 字时返回错误"
    },
    "constraints": [
        "不能添加用户未提及的经历",
        "原文质量高时给予肯定并提供轻度建议"
    ]
}